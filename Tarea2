
use db_jardineria
go

select *from cliente
--------------
select count(*) as total_clientes
from cliente

select count(*) as clientes_con_credito
from cliente;

select sum(limite_credito) as total_credito
from cliente;

select avg(limite_credito) as total
from cliente;

select max(limite_credito) as credito_maximo
from cliente;

select min(limite_credito) as credito_minimo
from cliente;

select COUNT(limite_credito) as totalcredito,
sum(limite_credito) as total,
MIN(limite_credito) as minimo,
max(limite_credito) as maximo
from cliente


select *from pedido

select COUNT(codigo_pedido) as cantidad_pedidos,
min(fecha_pedido) as primer_pedido,
max(fecha_pedido) as ultimo_pedido
from pedido

----------------total pedidos cliente >5
select codigo_cliente, count(*) as total_pedidos
from pedido
group by codigo_cliente
having count(*) >5;

----- promedio precio productos por gama (precio venta mayor 10)

select *from producto

select gama, avg(precio_venta) as precio_promedio
from producto
group by gama
having avg(precio_venta) >10;

-----total pagado por cada cliente (solo los que han pagado mucho)

select *from pago

select codigo_cliente, sum(total) as total_pagado
from pago
group by codigo_cliente
having sum(total) >10000;

select codigo_pedido, sum(cantidad) as total_producto
from detalle_pedido
group by codigo_pedido
having sum(cantidad) >200

select codigo_oficina, count(*) as cantidad_empleados
from empleado
group by codigo_oficina
having count(*) >=2


--clientes por pais (solo paises con muchos cliente)

select pais, count(nombre_cliente) as cantidad_clientes
from cliente
group by pais
having count(nombre_cliente) >1

